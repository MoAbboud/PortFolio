# ----------------------------------------------------------------------------
# whereyago backend — example environment.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# ----------------------------------------------------------------------------

# App
ENVIRONMENT=local          # local | staging | production
DEBUG=true
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false             # true in production for structured logs

# Security
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — JSON list OR comma-separated. Expo dev server defaults shown.
BACKEND_CORS_ORIGINS=["http://localhost:19006","http://localhost:8081"]

# Database (PostgreSQL). In docker-compose, POSTGRES_HOST is overridden to "db".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=whereyago
POSTGRES_PASSWORD=
POSTGRES_DB=whereyago
