# Where the app finds the whereyago backend API.
#   iOS simulator:     http://localhost:8000/api/v1
#   Android emulator:  http://10.0.2.2:8000/api/v1
#   Physical phone:    http://<YOUR-COMPUTER-LAN-IP>:8000/api/v1   (e.g. http://192.168.1.50:8000/api/v1)
#
# EXPO_PUBLIC_* values are embedded in the app at build time and read via
# process.env. The API URL is not a secret, so this is fine. Copy to `.env`.
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
